# Database — paste your Supabase PostgreSQL connection string here
# It looks like: postgresql://postgres.yueeevidzkhvqkioxzwx:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.yueeevidzkhvqkioxzwx:your_database_password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=no-reply@bharatmodules.com
TEAM_EMAIL=team@bharatmodules.com

# Google Login
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# SMS (MSG91 - Optional)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id

# File Upload (Cloudinary)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Application Settings
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
PORT=4000

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_SECRET=your_supabase_secret
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
